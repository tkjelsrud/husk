rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'first-user@example.com',
          'second-user@example.com'
        ];
    }

    match /entries/{docId} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser()
        && request.resource.data.textInput is string
        && request.resource.data.textInput.size() > 0
        && request.resource.data.textInput.size() <= 1500
        && request.resource.data.priority in ['low', 'normal', 'high']
        && request.resource.data.processed == false
        && request.resource.data.dueDate == null
        && request.resource.data.category in [
          'unknown',
          'work',
          'creative',
          'houseproj',
          'family',
          'general'
        ]
        && request.resource.data.addedByUid == request.auth.uid
        && request.resource.data.addedByEmail == request.auth.token.email
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
